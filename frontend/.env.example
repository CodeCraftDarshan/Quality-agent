# Backend API base URL used by the React app
VITE_API_BASE_URL="http://localhost:8000"

# Supabase project URL from Project Settings > API
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase publishable / anon key from Project Settings > API
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_or_anon_key"

# Optional UI defaults
VITE_COPILOT_VERSION="v2"
VITE_DEFAULT_CLUSTER_ID=""
VITE_DEFAULT_QUERY=""

# Optional dev bypass users mirrored from backend auth bypass config
VITE_AUTH_BYPASS_ENTRIES="1@gmail.com:1234:admin;2@gmail.com:1234:moderator;3@gmail.com:1234:registrar"
