# Ollama
OLLAMA_BASE_URL="http://host.docker.internal:11434"
OLLAMA_MODEL="llama3.2"
OLLAMA_FALLBACK_MODEL="llama3.1"
OLLAMA_TIMEOUT_SEC="60"
OLLAMA_NUM_PREDICT="512"

# Supabase
# Project URL from Supabase Project Settings > API
SUPABASE_PROJECT_URL="https://your-project-ref.supabase.co"
# JWT audience usually stays "authenticated"
SUPABASE_JWT_AUDIENCE="authenticated"
# Direct database or pooler URL from Supabase Project Settings > Database
SUPABASE_DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres"

# Optional auth override for local-only work
AUTH_BYPASS_ENABLED="false"

# Optional RAG / vector config
PINECONE_API_KEY="pcsk_..."
PINECONE_INDEX_NAME="auraqc-sops"
RAG_TOP_K="8"
RAG_CONTEXT_LIMIT="3"

# API behavior
CHAT_RATE_LIMIT_PER_MINUTE="20"
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
