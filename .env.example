# === OLLAMA (required) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_FALLBACK_MODEL=llama3.1
OLLAMA_TIMEOUT_SEC=60
OLLAMA_NUM_PREDICT=512
OLLAMA_FALLBACK_NUM_PREDICT=256

# === OLLAMA MODEL ROUTING (task-specific model selection) ===
# Each task type can use a different Ollama model for specialized handling.
# If not set, falls back to OLLAMA_MODEL for all tasks.
# Use these to deploy different models for different RCA phases.
OLLAMA_MODEL_RCA=
OLLAMA_MODEL_HYPOTHESIS=
OLLAMA_MODEL_CITATIONS=
OLLAMA_MODEL_CHALLENGE=
OLLAMA_MODEL_FALLBACK=

# === AUTH ===
# Local Supabase CLI defaults:
# SUPABASE_PROJECT_URL=http://127.0.0.1:54321
# SUPABASE_JWKS_URL=http://127.0.0.1:54321/auth/v1/keys
# SUPABASE_JWT_AUDIENCE=authenticated
# SUPABASE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_PROJECT_URL=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=
SUPABASE_DATABASE_URL=

# === AUTH BYPASS (dev only) ===
AUTH_BYPASS_ENABLED=false

# === DATABASE ===
# Falls back to SQLite (auraqc.db) if SUPABASE_DATABASE_URL is not set

# === RAG / PINECONE (optional) ===
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
RAG_TOP_K=5
RAG_CONTEXT_LIMIT=3000

# === RATE LIMITING ===
CHAT_RATE_LIMIT_PER_MINUTE=20

# === FINOPS ===
DAILY_TOKEN_BUDGET=100000

# === FRONTEND ===
VITE_API_BASE_URL=http://localhost:8000
# Local Supabase CLI defaults:
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_PUBLISHABLE_KEY=<anon key from `supabase start`>
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_COPILOT_VERSION=v2
VITE_DEFAULT_CLUSTER_ID=
VITE_DEFAULT_QUERY=

# === LEGACY (not used, kept for reference) ===
# GOOGLE_API_KEY=
# GOOGLE_CHAT_MODEL=
# GOOGLE_EMBEDDING_MODEL=
